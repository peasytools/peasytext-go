# peasytext-go — Text case, slugify, word count (Go)
# Theme: Catppuccin Mocha
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Catppuccin Mocha"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasytext-go — Text case, slugify, word count for Go"
Enter
Type "# peasytext.com"
Enter
Sleep 500ms

# Run the demo
Type "go run ./examples/demo/"
Enter
Sleep 5s
